<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Bibliothèque Application</display-name>

    <welcome-file-list>
        <welcome-file>login</welcome-file>
    </welcome-file-list>

    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
            <secure>false</secure>  <!-- Mettre true en production avec HTTPS -->
        </cookie-config>
    </session-config>

    <!-- Paramètres de debug pour afficher les stack traces -->
    <context-param>
        <param-name>debug</param-name>
        <param-value>true</param-value>  <!-- Mettre false en production -->
    </context-param>

    <!-- Pages d'erreur par code HTTP -->
    <error-page>
        <error-code>400</error-code>
        <location>/WEB-INF/views/error/400.jsp</location>
    </error-page>

    <error-page>
        <error-code>403</error-code>
        <location>/WEB-INF/views/error/403.jsp</location>
    </error-page>

    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error/404.jsp</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error/500.jsp</location>
    </error-page>

    <!-- Page d'erreur par type d'exception -->
    <error-page>
        <exception-type>jakarta.servlet.ServletException</exception-type>
        <location>/WEB-INF/views/error/500.jsp</location>
    </error-page>

    <error-page>
        <exception-type>java.lang.NullPointerException</exception-type>
        <location>/WEB-INF/views/error/500.jsp</location>
    </error-page>

    <!-- Page d'erreur par défaut -->
    <error-page>
        <location>/WEB-INF/views/error/default.jsp</location>
    </error-page>
</web-app>